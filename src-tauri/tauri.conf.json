{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Musicore",
  "version": "0.0.1",
  "identifier": "com.k44rme.musicore",
    "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Musicore",
        "width": 900,
        "height": 600,
        "decorations": false,
        "minWidth": 360,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com",
        "style-src-elem": "'self' 'unsafe-inline' https://fonts.googleapis.com",
        "font-src": "'self' https://fonts.gstatic.com data:",
        "script-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost http://tauri.localhost",
        "media-src": "'self' asset: http://asset.localhost"
      },
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$AUDIO/**",
          "$CONFIG"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../assets/*",
      "../assets/icons/*.svg",
      "../musicore.config.toml"
    ]
  }
}
