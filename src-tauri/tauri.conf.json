{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "musicore",
  "version": "0.0.1",
  "identifier": "com.k44rme.musicore",
    "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Musicore",
        "width": 900,
        "height": 600,
        "decorations": false,
        "minWidth": 360,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$AUDIO/**",
          "$CONFIG"
        ]
      }

    }
  },
  
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../musicore.config.toml",
      "../assets/"
    ]
  }
}
